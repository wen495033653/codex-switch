{
  "name": "codex-switch",
  "version": "5.2.15",
  "description": "Desktop tool for managing and switching Codex accounts.",
  "license": "MIT",
  "author": "Codex Switch contributors",
  "keywords": [
    "codex",
    "tauri",
    "account-switcher",
    "openai-compatible"
  ],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/wen495033653/codex-switch.git"
  },
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "dev:renderer": "vite --config vite.config.mjs",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "check:tauri": "node scripts/check-tauri.mjs",
    "build:renderer": "vite build --config vite.config.mjs",
    "check": "node scripts/check.mjs && npm run build:renderer",
    "dist": "npm run tauri:build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "lottie-web": "^5.13.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.1",
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.11"
  }
}
